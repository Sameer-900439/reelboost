# ── Server ──
PORT=3000
NODE_ENV=development

# ── MongoDB ──
# Sign up at https://www.mongodb.com/cloud/atlas (free tier)
# Replace with your connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/insta-views?retryWrites=true&w=majority

# ── SMM Panel API (replace with real credentials) ──
SMM_API_KEY=your_dummy_api_key_here
SMM_API_URL=https://example-smm-panel.com/api/v2

# ── CORS ──
# Set to your deployed frontend URL in production
# Use * or http://localhost:3000 for development
CORS_ORIGIN=*

# ── Razorpay (for payments) ──
# Sign up at https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
